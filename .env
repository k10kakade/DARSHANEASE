# ─────────────────────────────────────────────────────────
#  .env — Environment Variables for DarshanEase
#  ⚠️  Never commit this file to GitHub!
# ─────────────────────────────────────────────────────────

# MongoDB connection string
# For local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/darshanease

# For MongoDB Atlas (cloud), replace with your actual URI:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/darshanease

# Server port
PORT=5000

# JWT Secret key (use a long, random string in production)
JWT_SECRET=darshanease_jwt_secret_key_2025